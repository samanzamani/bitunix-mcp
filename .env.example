# Bitunix API credentials — create at https://www.bitunix.com (API management).
# SECURITY: disable withdrawal permission and bind an IP whitelist on the key.
# Leave both unset to run with public market data tools only.
BITUNIX_API_KEY=
BITUNIX_SECRET_KEY=

# Trading tools (place/cancel orders) are OFF unless this is exactly "true".
BITUNIX_ENABLE_TRADING=false
